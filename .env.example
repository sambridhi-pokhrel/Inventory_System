# Copy this file to .env and fill in your real values.
# The .env file is already in .gitignore — never commit it.

# Gmail SMTP (required for password reset emails)
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create an App Password for "Mail" → copy the 16-character code
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password
